#!/bin/sh
# Test-as-Contract commit-msg hook
# 规则：带 [tac-test] 或 [tac-build] 标签的 commit，其文件类型必须与标签语义一致。

COMMIT_MSG_FILE=$1
FIRST_LINE=$(head -n 1 "$COMMIT_MSG_FILE")

# 如果不是 tac 标签，跳过
if ! printf '%s' "$FIRST_LINE" | grep -qE '^\[(tac-test|tac-build)\]'; then
  exit 0
fi

TAG=$(printf '%s' "$FIRST_LINE" | sed -E 's/^\[(tac-test|tac-build)\].*$/\1/')

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
[ -z "$STAGED_FILES" ] && exit 0

HAS_IMPL=false
HAS_TEST=false

for file in $STAGED_FILES; do
  case "$file" in
    test/*|tests/*|__tests__/*|*.test.*|*.spec.*|e2e/*|spec/*|integration/*)
      HAS_TEST=true
      ;;
    src/*|app/*|lib/*|pages/*|components/*|server/*|client/*|api/*|services/*|workers/*|tools/*|bin/*)
      HAS_IMPL=true
      ;;
  esac
done

case "$TAG" in
  tac-test)
    if [ "$HAS_IMPL" = true ]; then
      echo ""
      echo "❌ [tac-test] commit 只能包含测试文件，不能包含实现代码。"
      echo ""
      echo "请把实现代码放到单独的 [tac-build] commit 中。"
      echo ""
      exit 1
    fi
    ;;
  tac-build)
    if [ "$HAS_TEST" = true ]; then
      echo ""
      echo "❌ [tac-build] commit 只能包含实现代码，不能包含测试文件。"
      echo ""
      echo "请把测试修改放到单独的 [tac-test] commit 中，或通过 /tac-story 回流。"
      echo ""
      exit 1
    fi
    ;;
esac

exit 0
